# ==========================================
# 南方电网电费查询系统 环境变量配置模板
# ==========================================

# ==========================================
# 1. 基础配置
# ==========================================
# 运行端口
PORT=3000

# 是否启用 Mock 模拟测试模式 (1 为启用，0 或留空为关闭)
# 在进行测试或没有真实南方电网账号时，开启此模式可生成模拟电网账户与月度用电明细
CSG_MOCK=

# ==========================================
# 2. 数据库配置 (SQLite)
# ==========================================
# 数据库存储目录 (默认为项目根目录下的 ./data)
CSG_DATA_DIR=./data

# 数据库文件路径 (若配置此项，将覆盖 CSG_DATA_DIR 的默认生成路径)
# CSG_DATABASE_PATH=./data/csg-stat.sqlite

# ==========================================
# 3. 身份验证加固配置 (Better Auth)
# ==========================================
# 用于 Token 签名与敏感信息哈希加密的强加密密钥（生产环境部署时必须配置）
# 推荐生成方式：在命令行执行 `openssl rand -hex 32`，复制生成的 64 位字符填入此处
BETTER_AUTH_SECRET=your_better_auth_secret_minimum_32_characters

# 本应用的外部访问基准 URL（例如本地开发为 http://localhost:3000）
# 若使用公网或容器映射部署，请填写您的公网访问域名（如 https://csg-stat.yourdomain.com）
BETTER_AUTH_URL=http://localhost:3000

# ==========================================
# 4. MCP Agent 访问凭证配置
# ==========================================
# MCP 长期访问 token 的有效天数，默认 365 天；小于 300 或非法值会回退到默认值
MCP_TOKEN_EXPIRES_IN_DAYS=365
